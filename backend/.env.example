# Database URL (Postgres with pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/closet_db

# Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# Active in-memory catalog for the main backend
CATALOG_DATASET=dataset2

# Replicate API (for virtual try-on)
REPLICATE_API_TOKEN=your_replicate_api_token
